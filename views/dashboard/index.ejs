<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - MindSpace Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0a0a0f;
            color: #f0f0f0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar {
            background: rgba(10, 10, 15, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 198, 255, 0.2);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #4a00e0, #00c6ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .logo-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #00c6ff, #00d4aa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: #f0f0f0;
            text-decoration: none;
            transition: color 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 8px;
        }

        .nav-links a:hover, .nav-links a.active {
            color: #00c6ff;
            background: rgba(0, 198, 255, 0.1);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 16px;
            border-radius: 40px;
        }

        .username {
            color: #00c6ff;
            font-weight: 600;
        }

        .logout-btn {
            background: rgba(255, 107, 107, 0.2);
            padding: 6px 12px;
            border-radius: 8px;
            color: #ff6b6b;
            text-decoration: none;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            background: rgba(255, 107, 107, 0.4);
            color: #ff6b6b;
        }

        /* Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Welcome Section */
        .welcome-section {
            background: linear-gradient(135deg, rgba(74, 0, 224, 0.2), rgba(0, 198, 255, 0.1));
            border-radius: 24px;
            padding: 2rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(0, 198, 255, 0.2);
        }

        .welcome-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .welcome-subtitle {
            color: rgba(255, 255, 255, 0.7);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 1.5rem;
            border: 1px solid rgba(0, 198, 255, 0.1);
            transition: all 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: #00c6ff;
            box-shadow: 0 10px 30px rgba(0, 198, 255, 0.1);
        }

        .stat-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: #00c6ff;
        }

        .stat-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.9rem;
        }

        /* Platform Cards */
        .platforms-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

        .platforms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .platform-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            padding: 1.8rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .platform-card:hover {
            transform: translateY(-5px);
            border-color: #00c6ff;
        }

        .platform-icon {
            width: 60px;
            height: 60px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 1rem;
        }

        .neuromatrix-icon { background: linear-gradient(135deg, rgba(74, 0, 224, 0.3), rgba(0, 198, 255, 0.3)); color: #00c6ff; }
        .neurozen-icon { background: linear-gradient(135deg, rgba(0, 212, 255, 0.3), rgba(157, 78, 221, 0.3)); color: #00d4ff; }
        .zenscape-icon { background: linear-gradient(135deg, rgba(0, 212, 170, 0.3), rgba(0, 198, 255, 0.3)); color: #00d4aa; }

        .platform-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .platform-desc {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.9rem;
            line-height: 1.5;
        }

        /* Recent Sessions */
        .recent-sessions {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            padding: 1.5rem;
            margin-top: 1rem;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .section-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.3rem;
        }

        .view-all-link {
            color: #00c6ff;
            text-decoration: none;
            transition: opacity 0.3s;
        }

        .view-all-link:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        .session-list {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        .session-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            border-left: 3px solid #00c6ff;
        }

        .session-info h4 {
            margin-bottom: 0.3rem;
        }

        .session-info p {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.5);
        }

        .session-duration {
            font-weight: 600;
            color: #00d4aa;
        }

        /* Achievements */
        .achievements-grid {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }

        .achievement-badge {
            background: rgba(0, 198, 255, 0.1);
            border-radius: 40px;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
        }

        /* Chart */
        .chart-container {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        canvas {
            max-height: 300px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 2rem;
            color: rgba(255, 255, 255, 0.5);
        }

        @media (max-width: 768px) {
            .navbar-container {
                flex-direction: column;
                text-align: center;
            }
            
            .container {
                padding: 1rem;
            }
            
            .welcome-title {
                font-size: 1.5rem;
            }
            
            .platforms-grid {
                grid-template-columns: 1fr;
            }
            
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        .emergency-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #ff6b6b, #ff4757);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 5px 20px rgba(255, 107, 107, 0.4);
            transition: all 0.3s;
            z-index: 1000;
            border: none;
            color: white;
        }

        .emergency-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 5px 30px rgba(255, 107, 107, 0.6);
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/dashboard" class="logo">
                <div class="logo-icon"><i class="fas fa-infinity"></i></div>
                <div class="logo-text">MindSpace Portal</div>
            </a>
            
            <div class="nav-links">
                <a href="/dashboard" class="active"><i class="fas fa-chart-line"></i> Dashboard</a>
                <a href="/dashboard/neuromatrix"><i class="fas fa-brain"></i> Neuromatrix</a>
                <a href="/dashboard/neurozen"><i class="fas fa-brain"></i> NeuroZen</a>
                <a href="/dashboard/zenscape"><i class="fas fa-spa"></i> ZenScape</a>
            </div>
            
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                <span class="username"><%= user && (user.full_name || user.username) %></span>
                <a href="/auth/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
        </div>
    </nav>
    
    <div class="container">
        <!-- Welcome Section -->
        <div class="welcome-section">
            <h1 class="welcome-title">Welcome back, <%= user && (user.full_name || user.username) %>! 👋</h1>
            <p class="welcome-subtitle">Your journey to mental wellness continues. Ready to explore today?</p>
        </div>
        
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-clock"></i></div>
                <div class="stat-value"><%= stats && stats.total_minutes ? stats.total_minutes : 0 %></div>
                <div class="stat-label">Total Mindful Minutes</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="stat-value"><%= stats && stats.current_streak ? stats.current_streak : 0 %></div>
                <div class="stat-label">Day Streak</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                <div class="stat-value"><%= stats && stats.total_sessions ? stats.total_sessions : 0 %></div>
                <div class="stat-label">Sessions Completed</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-trophy"></i></div>
                <div class="stat-value"><%= achievements ? achievements.length : 0 %></div>
                <div class="stat-label">Achievements Earned</div>
            </div>
        </div>
        
        <!-- Weekly Activity Chart -->
        <div class="chart-container">
            <h3 style="margin-bottom: 1rem;"><i class="fas fa-chart-bar"></i> Weekly Activity</h3>
            <canvas id="weeklyChart"></canvas>
        </div>
        
        <!-- Platforms -->
        <h2 class="platforms-title">Choose Your Experience</h2>
        <div class="platforms-grid">
            <a href="/dashboard/neuromatrix" class="platform-card">
                <div class="platform-icon neuromatrix-icon"><i class="fas fa-brain"></i></div>
                <h3 class="platform-title">Neuromatrix</h3>
                <p class="platform-desc">Map your cognitive patterns with 3D brain visualization and neural analysis</p>
            </a>
            <a href="/dashboard/neurozen" class="platform-card">
                <div class="platform-icon neurozen-icon"><i class="fas fa-brain"></i></div>
                <h3 class="platform-title">NeuroZen</h3>
                <p class="platform-desc">Voice-guided therapy, breathing exercises, and emergency stress protocols</p>
            </a>
            <a href="/dashboard/zenscape" class="platform-card">
                <div class="platform-icon zenscape-icon"><i class="fas fa-spa"></i></div>
                <h3 class="platform-title">ZenScape</h3>
                <p class="platform-desc">Abstract art, therapeutic soundscapes, and guided meditation</p>
            </a>
        </div>
        
        <!-- Recent Sessions -->
        <div class="recent-sessions">
            <div class="section-header">
                <h3><i class="fas fa-history"></i> Recent Sessions</h3>
                <a href="/dashboard/sessions" class="view-all-link">View All →</a>
            </div>
            <div class="session-list">
                <% if (recentSessions && recentSessions.length > 0) { %>
                    <% recentSessions.forEach(function(session) { %>
                    <div class="session-item">
                        <div class="session-info">
                            <h4><%= session.technique_name %></h4>
                            <p><i class="far fa-calendar-alt"></i> <%= new Date(session.completed_at).toLocaleDateString() %></p>
                        </div>
                        <div class="session-duration"><%= session.duration %> min</div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-calendar-day" style="font-size: 2rem; margin-bottom: 1rem; display: block;"></i>
                        <p>No sessions yet. Start your first session!</p>
                    </div>
                <% } %>
            </div>
        </div>
        
        <!-- Achievements -->
        <% if (achievements && achievements.length > 0) { %>
        <div class="recent-sessions" style="margin-top: 1.5rem;">
            <div class="section-header">
                <h3><i class="fas fa-medal"></i> Your Achievements</h3>
            </div>
            <div class="achievements-grid">
                <% achievements.forEach(function(ach) { %>
                <div class="achievement-badge">
                    <i class="fas fa-trophy"></i> <%= ach.name %>
                </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </div>
    
    <!-- Emergency Button -->
    <button class="emergency-btn" onclick="triggerEmergency()">
        <i class="fas fa-exclamation-triangle"></i>
    </button>
    
    <script>
        // Weekly Chart
        const ctx = document.getElementById('weeklyChart').getContext('2d');
        let weeklyData = <%- JSON.stringify(weeklyData || []) %>;
        
        const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
        const data = new Array(7).fill(0);
        
        if (weeklyData && weeklyData.length > 0) {
            weeklyData.forEach(function(item) {
                const dayIndex = days.indexOf(item.day);
                if (dayIndex !== -1) {
                    data[dayIndex] = item.minutes;
                }
            });
        }
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: days,
                datasets: [{
                    label: 'Mindful Minutes',
                    data: data,
                    borderColor: '#00c6ff',
                    backgroundColor: 'rgba(0, 198, 255, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#00c6ff',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.1)' },
                        ticks: { color: '#fff' }
                    },
                    x: {
                        grid: { color: 'rgba(255,255,255,0.1)' },
                        ticks: { color: '#fff' }
                    }
                }
            }
        });
        
        function triggerEmergency() {
            if (confirm('🚨 EMERGENCY PROTOCOL\n\nThis will activate immediate grounding techniques. Continue?')) {
                fetch('/dashboard/api/emergency', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ technique_used: 'emergency_button', notes: 'User triggered emergency protocol' })
                }).catch(function(err) {
                    console.error('Emergency log error:', err);
                });
                
                alert('🆘 Emergency Protocol Activated\n\n' +
                      '1. Take 5 deep breaths\n' +
                      '2. Name 5 things you see\n' +
                      '3. Name 4 things you hear\n' +
                      '4. Name 3 things you feel\n' +
                      '5. Name 2 things you smell\n' +
                      '6. Name 1 thing you taste\n\n' +
                      'You are safe. This will pass.');
            }
        }
    </script>
</body>
</html>