<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - MindSpace Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
            padding: 40px 0;
        }

        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 80% 20%, rgba(0, 212, 170, 0.3) 0%, transparent 50%),
                radial-gradient(circle at 20% 80%, rgba(0, 198, 255, 0.2) 0%, transparent 50%);
            animation: pulse 8s ease-in-out infinite;
            z-index: 0;
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.5; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.05); }
        }

        .signup-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 550px;
            margin: 20px;
        }

        .signup-card {
            background: rgba(10, 10, 15, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 40px;
            border: 1px solid rgba(0, 198, 255, 0.2);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            animation: fadeInUp 0.6s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            text-align: center;
            margin-bottom: 25px;
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #4a00e0, #00c6ff);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 12px;
            animation: spin 10s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .logo-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 26px;
            font-weight: 700;
            background: linear-gradient(135deg, #00c6ff, #00d4aa);
            --webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .tagline {
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            margin-top: 5px;
        }

        h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 26px;
            text-align: center;
            margin-bottom: 25px;
            color: #fff;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .input-group {
            margin-bottom: 18px;
        }

        .input-group label {
            display: block;
            margin-bottom: 6px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 13px;
            font-weight: 500;
        }

        .input-group input,
        .input-group select {
            width: 100%;
            padding: 12px 15px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 198, 255, 0.2);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s;
        }

        .input-group input:focus,
        .input-group select:focus {
            outline: none;
            border-color: #00c6ff;
            box-shadow: 0 0 12px rgba(0, 198, 255, 0.3);
        }

        .input-group input::placeholder,
        .input-group select {
            color: rgba(255, 255, 255, 0.4);
        }

        .input-group select option {
            background: #1a1a2e;
        }

        .error-message {
            background: rgba(255, 107, 107, 0.2);
            border: 1px solid #ff6b6b;
            border-radius: 10px;
            padding: 10px;
            margin-bottom: 20px;
            color: #ff6b6b;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .signup-btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #4a00e0, #00c6ff);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .signup-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(74, 0, 224, 0.4);
        }

        .login-link {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.6);
            font-size: 14px;
        }

        .login-link a {
            color: #00c6ff;
            text-decoration: none;
            font-weight: 600;
        }

        .login-link a:hover {
            text-decoration: underline;
        }

        .back-home {
            text-align: center;
            margin-top: 18px;
        }

        .back-home a {
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .back-home a:hover {
            color: #00c6ff;
        }

        .terms {
            text-align: center;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.4);
            margin-top: 20px;
        }

        @media (max-width: 550px) {
            .signup-card {
                padding: 30px 20px;
            }
            
            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }
            
            .logo-text {
                font-size: 22px;
            }
            
            h2 {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-animation"></div>
    
    <div class="signup-container">
        <div class="signup-card">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-infinity"></i>
                </div>
                <div class="logo-text">MindSpace Portal</div>
                <div class="tagline">Start Your Wellness Journey</div>
            </div>
            
            <h2>Create Account</h2>
            
            <% if (error) { %>
            <div class="error-message">
                <i class="fas fa-exclamation-triangle"></i>
                <%= error %>
            </div>
            <% } %>
            
            <form action="/auth/signup" method="POST">
                <div class="input-group">
                    <label><i class="fas fa-user"></i> Full Name</label>
                    <input type="text" name="full_name" placeholder="Enter your full name" value="<%= formData.full_name || '' %>">
                </div>
                
                <div class="form-row">
                    <div class="input-group">
                        <label><i class="fas fa-at"></i> Username</label>
                        <input type="text" name="username" placeholder="Choose username" value="<%= formData.username || '' %>" required>
                    </div>
                    
                    <div class="input-group">
                        <label><i class="fas fa-envelope"></i> Email</label>
                        <input type="email" name="email" placeholder="Your email address" value="<%= formData.email || '' %>" required>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="input-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <input type="password" name="password" placeholder="Create password" required>
                    </div>
                    
                    <div class="input-group">
                        <label><i class="fas fa-check-circle"></i> Confirm Password</label>
                        <input type="password" name="confirmPassword" placeholder="Confirm password" required>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="input-group">
                        <label><i class="fas fa-calendar"></i> Age</label>
                        <input type="number" name="age" placeholder="Your age" value="<%= formData.age || '' %>">
                    </div>
                    
                    <div class="input-group">
                        <label><i class="fas fa-venus-mars"></i> Gender</label>
                        <select name="gender">
                            <option value="">Prefer not to say</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                </div>
                
                <button type="submit" class="signup-btn">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>
            </form>
            
            <div class="login-link">
                Already have an account? <a href="/auth/login">Sign In</a>
            </div>
            
            <div class="back-home">
                <a href="/">
                    <i class="fas fa-home"></i> Back to Home
                </a>
            </div>
            
            <div class="terms">
                By signing up, you agree to our Terms of Service and Privacy Policy
            </div>
        </div>
    </div>
</body>
</html>